{
  "$schema": "../../agents/schemas/steps_registry.schema.json",
  "agentId": "triager",
  "version": "2.0.0",
  "c1": "steps",
  "pathTemplate": "{c1}/{c2}/{c3}/f_{edition}_{adaptation}.md",
  "pathTemplateNoAdaptation": "{c1}/{c2}/{c3}/f_{edition}.md",
  "entryStepMapping": {
    "poll:state": "triage"
  },
  "steps": {
    "triage": {
      "stepId": "triage",
      "name": "Triage Single Issue",
      "stepKind": "closure",
      "c2": "closure",
      "c3": "triage",
      "edition": "default",
      "uvVariables": [
        "issue",
        "workflow"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "triager.schema.json",
        "schema": "triage"
      },
      "structuredGate": {
        "allowedIntents": [
          "closing",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "closing",
        "handoffFields": []
      },
      "transitions": {
        "closing": {
          "target": null
        },
        "repeat": {
          "target": "triage"
        }
      },
      "description": "Single-issue closure step: read issue body, classify (kind:impl|kind:consider|kind:design), pick smallest unused order:N, emit closing structured output. The poll:state boundary hook then applies the labels via gh issue edit. closure_action='label-only' keeps the issue open."
    }
  }
}
