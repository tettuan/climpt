{
  "$schema": "../../agents/schemas/steps_registry.schema.json",
  "agentId": "detailer",
  "version": "1.0.0",
  "c1": "steps",
  "pathTemplate": "{c1}/{c2}/{c3}/f_{edition}_{adaptation}.md",
  "pathTemplateNoAdaptation": "{c1}/{c2}/{c3}/f_{edition}.md",
  "entryStepMapping": {
    "count:iteration": {
      "initial": "detail",
      "continuation": "detail"
    }
  },
  "steps": {
    "detail": {
      "stepId": "detail",
      "name": "Detail Implementation Spec",
      "kind": "closure",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "detail",
        "edition": "default"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "description": "Single-iteration closure: read issue body + considerer comment, compose Implementation Spec (5 sections), post one comment, emit closing. Verdict {handoff-impl|blocked} routes downstream via workflow.json outputPhases.",
      "outputSchemaRef": {
        "file": "detailer.schema.json",
        "schema": "closure.detail"
      },
      "structuredGate": {
        "allowedIntents": [
          "closing"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "closing",
        "handoffFields": [
          "verdict",
          "detail_summary",
          "spec_comment_url",
          "blocked_reason"
        ]
      },
      "transitions": {
        "closing": {
          "target": null
        }
      }
    }
  }
}
