{
  "agentId": "iterator",
  "version": "3.0.0",
  "c1": "steps",
  "pathTemplate": "{c1}/{c2}/{c3}/f_{edition}_{adaptation}.md",
  "pathTemplateNoAdaptation": "{c1}/{c2}/{c3}/f_{edition}.md",
  "entryStepMapping": {
    "poll:state": {
      "initial": "initial.issue",
      "continuation": "continuation.issue"
    }
  },
  "failurePatterns": {
    "git-dirty": {
      "description": "\u672a\u30b3\u30df\u30c3\u30c8\u306e\u5909\u66f4\u304c\u3042\u308b",
      "edition": "failed",
      "adaptation": "git-dirty",
      "params": [
        "changedFiles",
        "untrackedFiles"
      ]
    },
    "test-failed": {
      "description": "\u30c6\u30b9\u30c8\u304c\u5931\u6557",
      "edition": "failed",
      "adaptation": "test-failed",
      "params": [
        "failedTests",
        "errorOutput"
      ]
    },
    "type-error": {
      "description": "\u578b\u30a8\u30e9\u30fc",
      "edition": "failed",
      "adaptation": "type-error",
      "params": [
        "errors",
        "files"
      ]
    },
    "lint-error": {
      "description": "\u30ea\u30f3\u30c8\u30a8\u30e9\u30fc",
      "edition": "failed",
      "adaptation": "lint-error",
      "params": [
        "errors",
        "files"
      ]
    },
    "format-error": {
      "description": "\u30d5\u30a9\u30fc\u30de\u30c3\u30c8\u30a8\u30e9\u30fc",
      "edition": "failed",
      "adaptation": "format-error",
      "params": [
        "files",
        "diff"
      ]
    },
    "file-not-exists": {
      "description": "\u5fc5\u8981\u306a\u30d5\u30a1\u30a4\u30eb\u304c\u5b58\u5728\u3057\u306a\u3044",
      "edition": "failed",
      "adaptation": "file-not-exists",
      "params": [
        "missingFiles",
        "expectedPath"
      ]
    },
    "branch-not-pushed": {
      "description": "\u30d6\u30e9\u30f3\u30c1\u304c\u30ea\u30e2\u30fc\u30c8\u306b\u30d7\u30c3\u30b7\u30e5\u3055\u308c\u3066\u3044\u306a\u3044",
      "edition": "failed",
      "adaptation": "branch-not-pushed",
      "params": [
        "branchName",
        "remoteStatus"
      ]
    },
    "branch-not-merged": {
      "description": "\u30d6\u30e9\u30f3\u30c1\u304c\u30de\u30fc\u30b8\u3055\u308c\u3066\u3044\u306a\u3044",
      "edition": "failed",
      "adaptation": "branch-not-merged",
      "params": [
        "branchName",
        "baseBranch",
        "mergeStatus"
      ]
    },
    "commit-binding-missing": {
      "description": "No commit references (#<issue>)",
      "edition": "failed",
      "adaptation": "commit-binding-missing",
      "params": [
        "issue"
      ]
    },
    "off-run-only": {
      "description": "All commits referencing this issue pre-date the run",
      "edition": "failed",
      "adaptation": "off-run-only",
      "params": [
        "issue",
        "run_started_sha"
      ]
    },
    "ac-evidence-missing": {
      "description": "One or more ACs have empty evidence_paths",
      "edition": "failed",
      "adaptation": "ac-evidence-missing",
      "params": [
        "missing_ac_ids"
      ]
    },
    "ac-typed-prefix-violated": {
      "description": "Typed ACs reference paths that fail prefix or ls check",
      "edition": "failed",
      "adaptation": "ac-typed-prefix-violated",
      "params": [
        "violating_ac_ids"
      ]
    },
    "kind-boundary-breach": {
      "description": "Changed paths violate the iterator scope rule for the issue's current kind:* label",
      "edition": "failed",
      "adaptation": "kind-boundary-breach",
      "params": [
        "kind_boundary_violations"
      ]
    }
  },
  "validators": {
    "git-clean": {
      "type": "command",
      "phase": "postllm",
      "command": "git status --porcelain",
      "successWhen": "empty",
      "failurePattern": "git-dirty",
      "extractParams": {
        "changedFiles": "parseChangedFiles",
        "untrackedFiles": "parseUntrackedFiles"
      }
    },
    "tests-pass": {
      "type": "command",
      "phase": "postllm",
      "command": "deno task test",
      "successWhen": "exitCode:0",
      "failurePattern": "test-failed",
      "extractParams": {
        "failedTests": "parseTestOutput",
        "errorOutput": "stderr"
      }
    },
    "type-check": {
      "type": "command",
      "phase": "postllm",
      "command": "deno check src/**/*.ts agents/**/*.ts *.ts",
      "successWhen": "exitCode:0",
      "failurePattern": "type-error",
      "extractParams": {
        "errors": "parseTypeErrors",
        "files": "extractFiles"
      }
    },
    "lint-check": {
      "type": "command",
      "phase": "postllm",
      "command": "deno task lint",
      "successWhen": "exitCode:0",
      "failurePattern": "lint-error",
      "extractParams": {
        "errors": "parseLintErrors",
        "files": "extractFiles"
      }
    },
    "format-check": {
      "type": "command",
      "phase": "postllm",
      "command": "deno fmt --check",
      "successWhen": "exitCode:0",
      "failurePattern": "format-error",
      "extractParams": {
        "files": "parseFormatOutput",
        "diff": "generateDiff"
      }
    },
    "branch-pushed": {
      "type": "command",
      "phase": "postllm",
      "command": "git rev-parse --abbrev-ref --symbolic-full-name @{u}",
      "successWhen": "exitCode:0",
      "failurePattern": "branch-not-pushed",
      "extractParams": {
        "branchName": "parseBranchName",
        "remoteStatus": "parseRemoteStatus"
      }
    },
    "branch-merged": {
      "type": "command",
      "phase": "postllm",
      "command": "git log origin/develop..HEAD --oneline",
      "successWhen": "empty",
      "failurePattern": "branch-not-merged",
      "extractParams": {
        "branchName": "parseBranchName",
        "baseBranch": "stdout",
        "mergeStatus": "parseMergeStatus"
      }
    },
    "commit-binding-nonempty": {
      "type": "command",
      "phase": "postllm",
      "command": "git log --grep='(#${issue})' --oneline | head -1",
      "successWhen": "non-empty",
      "failurePattern": "commit-binding-missing"
    },
    "commit-in-run": {
      "type": "command",
      "phase": "postllm",
      "command": "git rev-list ${run_started_sha}..HEAD --grep='(#${issue})' | head -1",
      "successWhen": "non-empty",
      "failurePattern": "off-run-only"
    },
    "ac-evidence-nonempty": {
      "type": "command",
      "phase": "postllm",
      "command": "test \"${ac_evidence_all_nonempty}\" = \"true\"",
      "successWhen": "exitCode:0",
      "failurePattern": "ac-evidence-missing"
    },
    "ac-typed-prefix-ok": {
      "type": "command",
      "phase": "postllm",
      "command": "test \"${ac_typed_all_ok}\" = \"true\"",
      "successWhen": "exitCode:0",
      "failurePattern": "ac-typed-prefix-violated"
    },
    "kind-boundary-clean": {
      "type": "command",
      "phase": "postllm",
      "command": "test -z \"${kind_boundary_violations}\"",
      "successWhen": "exitCode:0",
      "failurePattern": "kind-boundary-breach"
    }
  },
  "validationSteps": {
    "closure.issue.precheck-commit-exists": {
      "stepId": "closure.issue.precheck-commit-exists",
      "name": "Commit Binding Existence Validation",
      "address": {
        "c1": "steps",
        "c2": "retry",
        "c3": "issue",
        "edition": "precheck-commit-exists"
      },
      "preflightConditions": [],
      "postLLMConditions": [
        {
          "validator": "commit-binding-nonempty"
        }
      ],
      "onFailure": {
        "action": "retry",
        "maxAttempts": 3
      },
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "description": "RC2 S2a: verify each commit_list SHA exists and capture changed_paths. Missing binding → commit-binding-missing retry."
    },
    "closure.issue.precheck-commit-in-run": {
      "stepId": "closure.issue.precheck-commit-in-run",
      "name": "Commit In-Run Ancestry Validation",
      "address": {
        "c1": "steps",
        "c2": "retry",
        "c3": "issue",
        "edition": "precheck-commit-in-run"
      },
      "preflightConditions": [],
      "postLLMConditions": [
        {
          "validator": "commit-in-run"
        }
      ],
      "onFailure": {
        "action": "retry",
        "maxAttempts": 3
      },
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "description": "RC3: per-SHA off-run flag via git merge-base --is-ancestor against run_started_sha. Off-run only → off-run-only retry."
    },
    "closure.issue.precheck-ac-evidence-nonempty": {
      "stepId": "closure.issue.precheck-ac-evidence-nonempty",
      "name": "AC Evidence Non-Empty Validation",
      "address": {
        "c1": "steps",
        "c2": "retry",
        "c3": "issue",
        "edition": "precheck-ac-evidence-nonempty"
      },
      "preflightConditions": [],
      "postLLMConditions": [
        {
          "validator": "ac-evidence-nonempty"
        }
      ],
      "onFailure": {
        "action": "retry",
        "maxAttempts": 3
      },
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "description": "RC5 S3a: assert every ac_id has at least one evidence_path. Empty → ac-evidence-missing retry."
    },
    "closure.issue.precheck-ac-typed-prefix": {
      "stepId": "closure.issue.precheck-ac-typed-prefix",
      "name": "AC Typed Path Prefix Validation",
      "address": {
        "c1": "steps",
        "c2": "retry",
        "c3": "issue",
        "edition": "precheck-ac-typed-prefix"
      },
      "preflightConditions": [],
      "postLLMConditions": [
        {
          "validator": "ac-typed-prefix-ok"
        }
      ],
      "onFailure": {
        "action": "retry",
        "maxAttempts": 3
      },
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "description": "RC5 S3b: typed ACs (fixture/prompt/template/schema) respect required prefix and `ls` succeeds. Violation → ac-typed-prefix-violated retry."
    },
    "closure.issue.precheck-kind-scope": {
      "stepId": "closure.issue.precheck-kind-scope",
      "name": "Kind Boundary Scope Validation",
      "address": {
        "c1": "steps",
        "c2": "retry",
        "c3": "issue",
        "edition": "precheck-kind-scope"
      },
      "preflightConditions": [],
      "postLLMConditions": [
        {
          "validator": "kind-boundary-clean"
        }
      ],
      "onFailure": {
        "action": "retry",
        "maxAttempts": 3
      },
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "description": "RC6: assert kind_boundary_violations is empty. Non-empty → kind-boundary-breach retry, which reverts only the listed out-of-scope paths."
    }
  },
  "steps": {
    "initial.issue": {
      "stepId": "initial.issue",
      "name": "Issue Initial Prompt",
      "type": "prompt",
      "kind": "work",
      "address": {
        "c1": "steps",
        "c2": "initial",
        "c3": "issue",
        "edition": "default"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "initial.issue"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "targetField": "next_action.details.target",
        "fallbackIntent": "next",
        "handoffFields": [
          "analysis.understanding",
          "analysis.approach",
          "issue"
        ]
      },
      "transitions": {
        "next": {
          "target": "continuation.issue"
        },
        "repeat": {
          "target": "initial.issue"
        }
      },
      "description": "Initial prompt when working on a single GitHub issue"
    },
    "continuation.issue": {
      "stepId": "continuation.issue",
      "name": "Issue Continuation Prompt",
      "kind": "work",
      "address": {
        "c1": "steps",
        "c2": "continuation",
        "c3": "issue",
        "edition": "default"
      },
      "uvVariables": [
        "issue",
        "completed_iterations"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "continuation.issue"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "repeat",
        "handoffFields": [
          "progress.completed_files",
          "progress.pending_tasks",
          "run_started_sha"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-commit-list"
        },
        "repeat": {
          "target": "continuation.issue"
        }
      },
      "description": "Continuation prompt for issue iterations. Pre: issue, completed_iterations. Verdict: next on implementation complete and pre-handoff git-clean checklist passed (advance to precheck chain); repeat to keep iterating in the work loop."
    },
    "closure.issue.precheck-commit-list": {
      "stepId": "closure.issue.precheck-commit-list",
      "name": "Precheck - Enumerate In-Run Commits",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-commit-list"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-commit-exists"
        },
        "repeat": {
          "target": "closure.issue.precheck-commit-list"
        }
      },
      "description": "RC2 S1: enumerate in-run commits referencing (#<issue>). Pre: run_started_sha (recorded at run start, propagated from continuation.issue handoff). Verdict: next on enumeration OK; repeat if git log fails or run_started_sha unreadable."
    },
    "closure.issue.precheck-commit-exists": {
      "stepId": "closure.issue.precheck-commit-exists",
      "name": "Precheck - Verify Commit SHAs Exist",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-commit-exists"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-commit-in-run"
        },
        "repeat": {
          "target": "closure.issue.precheck-commit-exists"
        }
      },
      "validationSteps": [
        "closure.issue.precheck-commit-exists"
      ],
      "description": "RC2 S2a: per-SHA existence + capture changed_paths. Pre: run_started_sha, commit_list. Verdict: next on every SHA exists (validator commit-binding-nonempty passes); repeat on commit-binding-missing (recovered via f_failed_commit-binding-missing.md adaptation)."
    },
    "closure.issue.precheck-commit-in-run": {
      "stepId": "closure.issue.precheck-commit-in-run",
      "name": "Precheck - Verify Commits Are In-Run",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-commit-in-run"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-kind-read"
        },
        "repeat": {
          "target": "closure.issue.precheck-commit-in-run"
        }
      },
      "validationSteps": [
        "closure.issue.precheck-commit-in-run"
      ],
      "description": "RC3: per-SHA off-run flag via git merge-base --is-ancestor against run_started_sha. Pre: commit_verification (with exists). Verdict: next on at least one in-run commit (validator commit-in-run passes); repeat on off-run-only (recovered via f_failed_off-run-only.md adaptation)."
    },
    "closure.issue.precheck-kind-read": {
      "stepId": "closure.issue.precheck-kind-read",
      "name": "Precheck - Read Kind At Triage Artifact",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-kind-read"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck-kind-read"
      },
      "structuredGate": {
        "allowedIntents": [
          "next"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-kind-scope"
        }
      },
      "description": "Best-effort read of .agent/climpt/out/kind_at_triage/<issue>.txt (audit-only). Missing/invalid → kind_at_triage:null. Always emits next; never repeats."
    },
    "closure.issue.precheck-kind-scope": {
      "stepId": "closure.issue.precheck-kind-scope",
      "name": "Precheck - Verify Kind Boundary Scope",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-kind-scope"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification",
          "kind_boundary_violations"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-ac-extract"
        },
        "repeat": {
          "target": "closure.issue.precheck-kind-scope"
        }
      },
      "validationSteps": [
        "closure.issue.precheck-kind-scope"
      ],
      "description": "RC6: Apply iterator's kind:* scope rule to commit_verification.changed_paths using the issue's live kind:* label. Pre: commit_verification (with changed_paths). Verdict: next on kind_boundary_violations empty (validator kind-boundary-clean passes); repeat on kind-boundary-breach (out-of-scope paths must be reverted)."
    },
    "closure.issue.precheck-ac-extract": {
      "stepId": "closure.issue.precheck-ac-extract",
      "name": "Precheck - Extract Acceptance Criteria",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-ac-extract"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification",
          "kind_boundary_violations",
          "ac_list"
        ]
      },
      "transitions": {
        "next": {
          "target": "closure.issue.precheck-ac-map"
        },
        "repeat": {
          "target": "closure.issue.precheck-ac-extract"
        }
      },
      "description": "RC5 S1: extract AC bullets from issue body into ac_list. Pre: issue (number, title, body fetched via gh). Verdict: next on AC bullets parsed (or zero ACs found); repeat if issue body fetch fails."
    },
    "closure.issue.precheck-ac-map": {
      "stepId": "closure.issue.precheck-ac-map",
      "name": "Precheck - Map AC to Evidence",
      "type": "prompt",
      "kind": "verification",
      "address": {
        "c1": "steps",
        "c2": "closure",
        "c3": "issue",
        "edition": "precheck-ac-map"
      },
      "uvVariables": [
        "issue"
      ],
      "usesStdin": false,
      "outputSchemaRef": {
        "file": "issue.schema.json",
        "schema": "closure.issue.precheck"
      },
      "structuredGate": {
        "allowedIntents": [
          "next",
          "repeat"
        ],
        "intentSchemaRef": "#/properties/next_action/properties/action",
        "intentField": "next_action.action",
        "fallbackIntent": "next",
        "handoffFields": [
          "run_started_sha",
          "commit_list",
          "commit_verification",
          "kind_boundary_violations",
          "ac_list",
          "ac_mapping"
        ]
      },
