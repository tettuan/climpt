{
  "$schema": "../agents/orchestrator/workflow-schema.json",
  "version": "1.0.0",
  "issueSource": {
    "kind": "ghRepoIssues",
    "projectMembership": "unbound"
  },
  "phases": {
    "impl-pending": {
      "type": "actionable",
      "priority": 1,
      "agent": "iterator"
    },
    "detail-pending": {
      "type": "actionable",
      "priority": 2,
      "agent": "detailer"
    },
    "consider-pending": {
      "type": "actionable",
      "priority": 3,
      "agent": "considerer"
    },
    "blocked": {
      "type": "actionable",
      "priority": 4,
      "agent": "clarifier"
    },
    "plan-pending": {
      "type": "actionable",
      "priority": 5,
      "agent": "project-planner"
    },
    "done": {
      "type": "terminal"
    }
  },
  "labelMapping": {
    "kind:impl": "impl-pending",
    "kind:detail": "detail-pending",
    "kind:consider": "consider-pending",
    "done": "done",
    "need clearance": "blocked",
    "kind:plan": "plan-pending"
  },
  "labels": {
    "kind:impl": {
      "color": "a2eeef",
      "description": "Implementation work (iterator)"
    },
    "kind:detail": {
      "color": "fbca04",
      "description": "Specification detailing (detailer)"
    },
    "kind:consider": {
      "color": "bfd4f2",
      "description": "Consideration/response (considerer)"
    },
    "done": {
      "color": "0e8a16",
      "description": "Work completed (awaiting orchestrator close)"
    },
    "need clearance": {
      "color": "d93f0b",
      "description": "Blocked — requires human clearance"
    },
    "kind:plan": {
      "color": "c5def5",
      "description": "Planning request (project-planner)"
    },
    "project-sentinel": {
      "color": "e6e6e6",
      "description": "Sentinel issue for project lifecycle (planner/evaluator)",
      "role": "marker"
    }
  },
  "agents": {
    "iterator": {
      "role": "transformer",
      "directory": "iterator",
      "outputPhase": "done",
      "fallbackPhase": "blocked",
      "closeBinding": {
        "primary": { "kind": "direct" },
        "cascade": false
      }
    },
    "considerer": {
      "role": "validator",
      "directory": "considerer",
      "outputPhases": {
        "done": "done",
        "handoff-detail": "detail-pending"
      },
      "fallbackPhase": "blocked",
      "closeBinding": {
        "primary": { "kind": "direct" },
        "cascade": false,
        "condition": "done"
      }
    },
    "detailer": {
      "role": "validator",
      "directory": "detailer",
      "outputPhases": {
        "handoff-impl": "impl-pending",
        "blocked": "blocked"
      },
      "fallbackPhase": "blocked",
      "closeBinding": {
        "primary": { "kind": "none" },
        "cascade": false
      }
    },
    "clarifier": {
      "role": "validator",
      "directory": "clarifier",
      "outputPhases": {
        "ready-to-impl": "impl-pending",
        "ready-to-consider": "consider-pending"
      },
      "fallbackPhase": "blocked",
      "closeBinding": {
        "primary": { "kind": "none" },
        "cascade": false
      }
    },
    "project-planner": {
      "role": "transformer",
      "directory": "project-planner",
      "outputPhase": "done",
      "fallbackPhase": "blocked",
      "closeBinding": {
        "primary": { "kind": "none" },
        "cascade": false
      }
    }
  },
  "handoff": {
    "commentTemplates": {
      "considererHandoffDetail": "## Specification Requested\n\n{final_summary}",
      "detailerHandoffImpl": "## Implementation Spec\n\n{detail_summary}",
      "clarifierReadyToImpl": "## Clarifier: ready-to-impl\n\n{final_summary}",
      "clarifierReadyToConsider": "## Clarifier: ready-to-consider\n\n{final_summary}",
      "iteratorFailed": "<!-- iterator-failure-v1 -->\n## Iterator: failed\n\n{iterator_last_failure}"
    }
  },
  "rules": {
    "maxCycles": 11,
    "cycleDelayMs": 30000,
    "maxConsecutivePhases": 3
  },
  "subjectStore": {
    "path": ".agent/climpt/tmp/issues-execute"
  }
}
