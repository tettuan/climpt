{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(bash:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(claude:*)",
      "Bash(climpt:*)",
      "Bash(comm:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(deno:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(false:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(kill:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(pkill:*)",
      "Bash(printf:*)",
      "Bash(ps:*)",
      "Bash(pwd:*)",
      "Bash(python3:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(set:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(true:*)",
      "Bash(uname:*)",
      "Bash(unset:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(while:*)",
      "Bash(xargs:*)",
      "Bash(./examples/*:*)",
      "Climpt__*",
      "Skill(absolute-path-checker)",
      "Skill(agents-overview)",
      "Skill(branch-management)",
      "Skill(breakdown-logger)",
      "Skill(ci-troubleshooting)",
      "Skill(claude-api)",
      "Skill(commit)",
      "Skill(docs-consistency)",
      "Skill(docs-writing)",
      "Skill(examples-smoke-test)",
      "Skill(fix-checklist)",
      "Skill(functional-testing)",
      "Skill(git-gh-sandbox)",
      "Skill(github-project-creation)",
      "Skill(implement-logger)",
      "Skill(local-ci)",
      "Skill(loop)",
      "Skill(option-scoring)",
      "Skill(refactoring)",
      "Skill(release-procedure)",
      "Skill(schedule)",
      "Skill(simplify)",
      "Skill(update-changelog)",
      "Skill(update-config)",
      "Skill(update-docs)",
      "Skill(work-process)",
      "Skill(plugin-dev:create-plugin)",
      "Skill(plugin-dev:command-development)",
      "Skill(plugin-dev:plugin-settings)",
      "Skill(plugin-dev:skill-development)",
      "Skill(plugin-dev:mcp-integration)",
      "Skill(plugin-dev:plugin-structure)",
      "Skill(plugin-dev:hook-development)",
      "Skill(plugin-dev:agent-development)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:jsr.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-env .claude/hooks/validate-dangerous-commands.ts",
            "timeout": 5,
            "statusMessage": "危険コマンドを検証中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "deno fmt",
            "timeout": 30,
            "statusMessage": "フォーマット中..."
          }
        ]
      }
    ]
  },
  "sandbox": {
    "network": {
      "allowedHosts": [
        "jsr.io",
        "*.jsr.io",
        "deno.land",
        "*.deno.land",
        "github.com",
        "api.github.com"
      ]
    }
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "senlygan-plugins": {
      "source": {
        "source": "directory",
        "path": "./plugins"
      }
    }
  }
}
