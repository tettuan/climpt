{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "Workflow Configuration",
  "description": "Schema for .agent/workflow.json - orchestrator workflow definition",
  "type": "object",
  "required": ["version", "phases", "labelMapping", "agents"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "phases": {
      "type": "object",
      "description": "Phase definitions keyed by phase ID",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["actionable", "terminal", "blocking"]
          },
          "priority": {
            "type": "number",
            "description": "Selection priority for actionable phases (lower = higher priority)"
          },
          "agent": {
            "type": ["string", "null"],
            "description": "Agent ID to dispatch when this phase is active"
          }
        }
      }
    },
    "labelMapping": {
      "type": "object",
      "description": "GitHub label to phase ID mapping",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "description": "Declarative GitHub label specs keyed by label name. Every label referenced in labelMapping and prioritizer.labels must appear here. Color is a 6-char hex (no '#'). Orchestrator/triager sync these to the repository at startup.",
      "additionalProperties": {
        "type": "object",
        "required": ["color", "description"],
        "additionalProperties": false,
        "properties": {
          "color": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{6}$",
            "description": "GitHub label color as 6-char hex (no leading '#')."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable label description surfaced in GitHub UI."
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "description": "Agent definitions keyed by agent ID",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["transformer", "validator"]
          },
          "directory": {
            "type": "string",
            "description": "Agent directory name (defaults to agent ID if omitted)"
          },
          "fallbackPhase": {
            "type": "string",
            "description": "Phase to transition to on error"
          },
          "closeOnComplete": {
            "type": "boolean",
            "description": "Close the GitHub issue when this agent's outcome leads to a terminal phase"
          },
          "closeCondition": {
            "type": "string",
            "description": "Only close the issue when the outcome matches this value (requires closeOnComplete: true)"
          },
          "outputPhase": {
            "type": "string",
            "description": "Phase to transition to on successful completion (transformer only)"
          },
          "fallbackPhases": {
            "type": "object",
            "description": "Outcome-to-phase mapping for non-success results (transformer only). When defined, the agent's verdict selects the fallback phase. Unmatched outcomes fall back to fallbackPhase.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "outputPhases": {
            "type": "object",
            "description": "Judgment key to target phase mapping (validator only)",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "role": { "const": "transformer" } },
              "required": ["role"]
            },
            "then": {
              "required": ["role", "outputPhase"]
            }
          },
          {
            "if": {
              "properties": { "role": { "const": "validator" } },
              "required": ["role"]
            },
            "then": {
              "required": ["role", "outputPhases"]
            }
          }
        ]
      }
    },
    "rules": {
      "type": "object",
      "description": "Execution constraints for the orchestrator loop",
      "additionalProperties": false,
      "properties": {
        "maxCycles": {
          "type": "number",
          "description": "Maximum phase transition cycles per issue",
          "minimum": 1
        },
        "cycleDelayMs": {
          "type": "number",
          "description": "Delay in milliseconds between cycles (shows countdown with safe-stop message)",
          "minimum": 0
        },
        "maxConsecutivePhases": {
          "type": "integer",
          "minimum": 0,
          "description": "Block issue when same phase appears consecutively N times. 0 disables the check."
        }
      }
    },
    "handoff": {
      "type": "object",
      "description": "Inter-agent handoff configuration",
      "additionalProperties": false,
      "properties": {
        "commentTemplates": {
          "type": "object",
          "description": "Named comment templates posted to GitHub issues during agent handoff. Keys follow naming convention: {agentId}{Outcome} (primary) or {agentId}To{Outcome} (fallback). Outcome is capitalized (e.g., approved → Approved). Template variables are defined by the closure step's handoffFields in steps_registry.json, not by the framework. Unmatched placeholders are preserved as-is.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "issueStore": {
      "type": "object",
      "description": "Issue store configuration",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" }
      }
    },
    "prioritizer": {
      "type": "object",
      "description": "Prioritizer configuration",
      "additionalProperties": false,
      "required": ["agent", "labels"],
      "properties": {
        "agent": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "defaultLabel": { "type": "string" }
      }
    },
    "labelPrefix": {
      "type": "string",
      "description": "Optional label namespace prefix (e.g. 'docs' produces 'docs:ready')"
    },
    "handoffs": {
      "type": "array",
      "description": "Declarative handoff entries: source agent outcome → artifact emission + optional payload persistence",
      "items": {
        "type": "object",
        "required": ["id", "when", "emit", "payloadFrom", "persistPayloadTo"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Workflow-unique handoff identifier"
          },
          "when": {
            "type": "object",
            "required": ["fromAgent", "outcome"],
            "additionalProperties": false,
            "properties": {
              "fromAgent": {
                "type": "string",
                "description": "Source agent id (a key in agents[])"
              },
              "outcome": {
                "type": "string",
                "description": "Canonical outcome string"
              }
            }
          },
          "emit": {
            "type": "object",
            "required": ["type", "schemaRef", "path"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "description": "Artifact kind tag"
              },
              "schemaRef": {
                "type": "string",
                "description": "Registered schema reference, e.g. 'pr-merger-verdict@1.0.0'"
              },
              "path": {
                "type": "string",
                "description": "Target file path template (supports ${payload.*} expansion)"
              }
            }
          },
          "payloadFrom": {
            "type": "object",
            "description": "Payload key → JSONPath / literal expression mapping",
            "additionalProperties": { "type": "string" }
          },
          "persistPayloadTo": {
            "enum": ["issueStore", "none"],
            "description": "Where to persist the resolved payload after emit"
          }
        }
      }
    },
    "payloadSchema": {
      "type": "object",
      "required": ["$ref"],
      "additionalProperties": false,
      "description": "Reference to the JSON Schema used to validate IssuePayload instances for this workflow",
      "properties": {
        "$ref": { "type": "string" }
      }
    }
  }
}
