{
  "version": "1.0.0",
  "issueSource": {
    "kind": "ghRepoIssues",
    "projectMembership": "unbound"
  },
  "phases": {
    "implementation": {
      "type": "actionable",
      "priority": 2,
      "agent": "iterator"
    },
    "review": { "type": "actionable", "priority": 1, "agent": "reviewer" },
    "revision": { "type": "actionable", "priority": 3, "agent": "iterator" },
    "complete": { "type": "terminal" },
    "blocked": { "type": "blocking" }
  },
  "labelMapping": {
    "ready": "implementation",
    "review": "review",
    "implementation-gap": "revision",
    "done": "complete",
    "blocked": "blocked"
  },
  "agents": {
    "iterator": {
      "role": "transformer",
      "outputPhase": "review",
      "fallbackPhase": "blocked"
    },
    "reviewer": {
      "role": "validator",
      "outputPhases": { "approved": "complete", "rejected": "revision" },
      "fallbackPhase": "blocked"
    }
  },
  "rules": { "maxCycles": 5, "cycleDelayMs": 0 },
  "handoff": {
    "commentTemplates": {
      "iteratorSuccess": "[Handoff] Implementation complete.\n{final_summary}",
      "reviewerApproved": "[Review Complete] All requirements verified.\n{final_summary}",
      "reviewerRejected": "[Review] Gaps found.\n{final_summary}"
    }
  },
  "subjectStore": { "path": ".agent/climpt/tmp/issues" }
}
